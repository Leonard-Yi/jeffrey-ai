{
  "name": "jeffrey-ai",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "check-mem": "npx tsx scripts/check-resources.ts",
    "//": "⚠️ dev 已禁用！Turbopack 会瞬间产生十几个进程，极易导致内存爆满。仅使用生产模式。",
    "//": "如确需开发模式调试，请手动运行: npx tsx scripts/check-resources.ts && next dev -p 30081（但需自行注意内存）",
    "build": "cross-env NODE_OPTIONS=--max-old-space-size=8192 next build",
    "typecheck": "tsc --noEmit",
    "start": "next start",
    "lint": "next lint",
    "test:extract": "npx tsx --env-file=.env src/test/testExtractor.ts",
    "test:pipeline": "npx tsx --env-file=.env src/test/fullPipelineTest.ts",
    "test:graph": "npx tsx --env-file=.env scripts/test-graph.ts",
    "postinstall": "prisma generate",
    "refresh-embeddings": "npx tsx --env-file=.env scripts/force-refresh-embeddings.ts",
    "start:refresh": "npx tsx --env-file=.env scripts/force-refresh-embeddings.ts && next start"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.1",
    "@prisma/adapter-pg": "^7.6.0",
    "@prisma/client": "^7.7.0",
    "bcrypt": "^6.0.0",
    "d3-force": "^3.0.0",
    "dotenv": "^17.3.1",
    "next": "^16.2.1",
    "next-auth": "^5.0.0-beta.30",
    "nodemailer": "^7.0.13",
    "openai": "^4.47.0",
    "pg": "^8.20.0",
    "prisma": "^7.6.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.0",
    "@types/bcrypt": "^6.0.0",
    "@types/node": "^20.0.0",
    "@types/nodemailer": "^8.0.0",
    "@types/pg": "^8.20.0",
    "autoprefixer": "^10.4.27",
    "cross-env": "^10.1.0",
    "node-notifier": "^10.0.1",
    "postcss": "^8.5.8",
    "tailwindcss": "^3.4.0",
    "tsx": "^4.15.0",
    "typescript": "^5.4.0"
  },
  "description": "",
  "keywords": [],
  "author": "",
  "license": "ISC"
}
